                     xmlns:photoshop="http://ns.adobe.com/photoshop/1.0/"
                     xmlns:xmp="http://ns.adobe.com/xap/1.0/"
                     xmlns:xmpMM="http://ns.adobe.com/xap/1.0/mm/"
                     xmlns:stEvt="http://ns.adobe.com/xap/1.0/sType/ResourceEvent#"
